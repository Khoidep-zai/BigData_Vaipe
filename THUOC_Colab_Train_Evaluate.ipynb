        "print(\"   python run_all.py --data-dir data_aligned --device cuda --batch-size 16\")\n",
        "print(\"2) Compare only\")\n",
        "print(\"   python run_all.py --compare-only --data-dir data_aligned --device cuda\")\n",
        "print(\"3) Single model\")\n",
